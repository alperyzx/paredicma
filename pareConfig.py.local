# !/usr/bin/python
from pareNodeList import *

#set  your own parameters
projectName = 'releaseTest' + 'Cache'
pareOSUser = 'alper'
pareWebPort = 8000
redisVersion = '7.4.2'
redisTarFile = 'redis-7.4.2.tar.gz'
